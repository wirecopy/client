#!/bin/sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
VERSION=${WIRECOPY_VERSION:-0.1.0-dev}
DIST="$ROOT/dist"
APP="$DIST/Wirecopy.app"
CONTENTS="$APP/Contents"
ARM_DIR=$(swift build --package-path "$ROOT" -c release --triple arm64-apple-macosx14.0 --show-bin-path)
INTEL_DIR=$(swift build --package-path "$ROOT" -c release --triple x86_64-apple-macosx14.0 --show-bin-path)

swift build --package-path "$ROOT" -c release --triple arm64-apple-macosx14.0
swift build --package-path "$ROOT" -c release --triple x86_64-apple-macosx14.0
rm -rf "$APP"
mkdir -p "$CONTENTS/MacOS" "$CONTENTS/Resources"
lipo -create "$ARM_DIR/WirecopyApp" "$INTEL_DIR/WirecopyApp" -output "$CONTENTS/MacOS/WirecopyApp"
lipo -create "$ARM_DIR/WirecopyCLI" "$INTEL_DIR/WirecopyCLI" -output "$CONTENTS/MacOS/wirecopy"
ditto "$ARM_DIR/Wirecopy_WirecopyMac.bundle" "$CONTENTS/Resources/Wirecopy_WirecopyMac.bundle"

swift "$ROOT/scripts/make-icon.swift" "$DIST/icon-1024.png"
ICONSET="$DIST/Wirecopy.iconset"
rm -rf "$ICONSET"
mkdir -p "$ICONSET"
for size in 16 32 128 256 512; do
  sips -z "$size" "$size" "$DIST/icon-1024.png" --out "$ICONSET/icon_${size}x${size}.png" >/dev/null
  doubled=$((size * 2))
  sips -z "$doubled" "$doubled" "$DIST/icon-1024.png" --out "$ICONSET/icon_${size}x${size}@2x.png" >/dev/null
done
iconutil -c icns "$ICONSET" -o "$CONTENTS/Resources/Wirecopy.icns"
rm -rf "$ICONSET" "$DIST/icon-1024.png"

sed \
  -e "s/__VERSION__/$VERSION/g" \
  "$ROOT/scripts/Info.plist.template" > "$CONTENTS/Info.plist"

codesign --force --deep --sign - "$APP"
ditto -c -k --sequesterRsrc --keepParent "$APP" "$DIST/Wirecopy-$VERSION.zip"
shasum -a 256 "$DIST/Wirecopy-$VERSION.zip" > "$DIST/Wirecopy-$VERSION.zip.sha256"

echo "$APP"
